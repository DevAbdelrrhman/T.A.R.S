# =============================================================================
#                          TARS-AI CONFIGURATION
# =============================================================================
# This file defines all settings for your TARS-AI robot.
# Each setting includes a detailed description explaining what it does.
# In the Web UI, hover over the (i) icon next to any setting for details.
# After making changes, restart TARS for them to take effect.
# =============================================================================

[CHAR]
# Path to character JSON file (relative to src/)
character_card_path = character/TARS/TARS.json
# Your name — used in conversation
user_name = Cooper
# Brief description of yourself (e.g., "Species: Human. Gender: Male.")
user_details = Species: Human. Gender: Male.
# Human-readable location name (e.g., "City, State, Country")
location_name = Cheyenne Mountain, Colorado
# GPS coordinates for location-aware responses
latitude = 38.7372207
longitude = -104.8859561
# Phrases said immediately after the wake word (JSON array, [] for none)
responses = ["Hi","Yes?","hey!","What's up?","Can I help you?","What do you need?","I'm here.","You rang?","Yea?","Hey There.","You again?","Affirmative.","Ready.","Standing by.","Go ahead.","Listening.","How can I assist?","At your service.","Waiting.","What do you require?","I hear you.","Acknowledged.","State your request.","What's on your mind?","I'm all ears. Figuratively.","That's me.","Present.","Right here.","Still here.","Something wrong?","Need me?"]
# Enable/disable filler phrases while waiting for LLM response (true/false)
enable_thinking_responses = false
# Filler phrases said while waiting for LLM response (JSON array, [] for none)
thinking_responses = ["Let me think...","soooo.....","soo....","Let's seeee...","Let me seeee...","Let's see.....","One Moment...","One Moment","hum","humm","Analyzing...","Processing...","Calculating...","Computing...","Running the numbers...","Checking...","One moment...","Scanning data...","Assessing...","Evaluating...","Let me calculate...","Working on it...","Just a moment...","Reviewing...","Compiling...","Cross-referencing...","Thinking it through...","Give me a second...","Hold on..."]

[LLM]
# AI backend: openai | grok | deepinfra | other
llm_backend = other
# API endpoint URL (used when llm_backend = other)
base_url = https://api.featherless.ai
# Model name for openai / deepinfra backend (e.g., gpt-4o-mini)
openai_model = gpt-4o-mini
# Model name for grok backend
grok_model = grok-4-1-fast-non-reasoning
# Model name for other (custom) backend
other_model = meta-llama/Meta-Llama-3.1-8B-Instruct
# System instructions prepended to every conversation (keep general; personality goes in character card)
systemprompt = You are to responding naturally and helpfully within the scenario. Be informative and conversational while maintaining your personality.
# Max conversation history in tokens (2000–8000, check model docs)
contextsize = 16000
# Max tokens per LLM response (200–300 conversational, 500–1000 for detailed)
max_tokens = 1000
# Random seed (-1 = unique each time, fixed number = reproducible)
seed = -1
# Creativity: 0.0–2.0 (0.7–0.9 recommended for conversation)
temperature = 0.8
# Token diversity: 0.0–1.0 (0.9 recommended, leave as-is)
top_p = 0.9
# Force JSON output via API (True/False). Disable for backends that don't support response_format (e.g. LM Studio)
json_mode = True
# Token counting encoding — only change if token errors occur (cl100k_base works for most models)
override_encoding_model = cl100k_base

[STT]
# Spoken language (use openai stt_processor for non-English)
language = english
# Activation phrase — 2–3 syllables works best
wake_word = hey tars
# Wake word engine (independent of stt_processor — mix freely)
#   Pi5: sherpa-onnx | atomik | fastrtc
#   Pi4: sherpa-onnx | atomik
#   Pi3: sherpa-onnx | atomik
#   PiZero2: atomik
wake_word_processor = atomik
# Atomik detection mode (atomik only) auto = use ONNX model if available, otherwise fall back to template, model = ONNX model only (trained with tools/wakeword-trainer), template = cosine similarity only (record wake word 5 times on device)
atomik_mode = template
# Wake word gates — apply to all wake word engines
# Transcript verify: only active when wake_word_processor = atomik AND atomik_mode = template
vad_transcript_verify = False
vad_speaker_verify = off
vad_speaker_threshold = 0.60
vad_presence_gate = off
# Wake word strictness 1–10 (atomik only; 1 = lenient, 10 = strict)
sensitivity = 7
# Speech-to-text engine (independent of wake_word_processor — mix freely)
#   Pi5: sherpa-onnx | fastrtc | silero | openai | external
#   Pi4: sherpa-onnx | openai | external
#   Pi3: openai | external
#   PiZero2: openai
stt_processor = sherpa-onnx
# Play beep when listening starts and stops
use_indicators = True
# External STT server URL (stt_processor = external only)
external_url = http://192.168.1.100:5678
# End-of-speech detection (independent of stt/wake — mix freely)
#   Pi5: smart-turn | sherpa-onnx | silero | rms
#   Pi4: smart-turn | sherpa-onnx | silero | rms
#   Pi3: sherpa-onnx | rms
#   PiZero2: rms
vad_method = smart-turn
# Denoise audio before transcription (requires sherpa-onnx): True | False
sherpa_onnx_denoise = False
# Add punctuation to transcriptions (requires sherpa-onnx): True | False
sherpa_onnx_punctuation = False
# Enable barge-in detection — interrupt TARS by speaking while it talks: True | False
enable_bargein = True
# Barge-in detection mode: fuzzy (word matching) | voiceprint (speaker ID matching)
bargein_mode = voiceprint
# Barge-in sensitivity 1–10 (1 = hard to interrupt, 10 = very sensitive)
bargein_sensitivity = 5
# Silence before processing in tenths of a second (20 = 2s)
speechdelay = 15
# Speaker identification — passively identify who is speaking (Pi5/Pi4 only)
speaker_id_enabled = True
# Speaker ID cosine similarity threshold (0.0–1.0, higher = stricter matching)
speaker_id_threshold = 0.75
# Microphone amplification gain — multiplies raw mic input (higher = more sensitive, default 10.0)
mic_amp_gain = 13.0
# Silence margin — how many times above background noise counts as speech (lower = more sensitive, default 3.0)
silence_margin = 3.0

[TTS]
# Use voice settings from character card instead of settings above
toggle_charvoice = True
# TTS engine: espeak | piper | silero | elevenlabs | openai | other | external
ttsoption = piper
# External TTS server URL (ttsoption = other or external)
ttsurl = 
# Voice name/ID for external TTS server
tts_voice =
# ElevenLabs voice ID (find in elevenlabs.io dashboard)
elevenlabs_voice_id = JBFqnCBsd6RMkjVDRZzb
# ElevenLabs model: eleven_multilingual_v2 | eleven_monolingual_v1 | eleven_turbo_v2
elevenlabs_model = eleven_multilingual_v2
# OpenAI TTS voice: alloy | echo | fable | onyx | nova | shimmer
openai_voice = onyx
# Enable multi-speaker Piper model — maps detected emotion to a speaker ID (True/False)
piper_multispeaker = True
# Speaker ID for each emotion (only used when piper_multispeaker = True)
piper_speaker_joy = 0
piper_speaker_neutral = 1
piper_speaker_fear = 2
piper_speaker_curiosity = 3
piper_speaker_love = 4
piper_speaker_sadness = 5
piper_speaker_surprise = 6
piper_speaker_anger = 7

[EMOTION]
# Enable emotion detection
enabled = True
# Emotion detection method: classifier | llm
# classifier = local HuggingFace model (~500MB RAM, 28 fine-grained emotions)
# llm = LLM returns emotion in its JSON response (zero extra RAM, uses your existing LLM)
emotion_method = llm
# HuggingFace model for emotion analysis (only used when emotion_method = classifier)
# Use the ONNX variant for faster CPU inference: SamLowe/roberta-base-go_emotions-onnx
emotion_model = SamLowe/roberta-base-go_emotions-onnx

[VISION]
# Enable camera vision (~1GB RAM when active)
enabled = True
# Camera rotation in degrees: 0, 90, 180, 270
camera_rotation = 270
# Vision processor: blip | llm | openai | server_hosted
# blip = local BLIP model (~1GB RAM), generates short captions passed to LLM
# llm = sends image to your configured LLM backend (requires vision-capable model)
# openai = sends image to OpenAI GPT-4o-mini vision API (requires OPENAI_API_KEY)
# server_hosted = sends image to external BLIP server (set base_url below)
vision_processor = blip
# Use the same model/backend as your main LLM (True/False)
# When True, vision uses your LLM settings. When False, configure separate model below.
use_llm_backend = True
# Vision API base URL (only when use_llm_backend = False)
base_url = http://192.168.1.100:5678
# Model name for vision (only when use_llm_backend = False)
vision_model =
# Max tokens for vision response
vision_max_tokens = 150

[RAG]
# Enable long-term memory
enabled = True
# Create periodic topic summaries for extended memory
enable_topic_tracking = True
# Search method: naive (vector only) | hybrid (vector + keyword, recommended)
strategy = hybrid
# Surrounding entries to include with each retrieved memory (0-2, lower = less noise)
context_window = 2
# Top N memories that get context window expansion
max_memories = 3
# Number of memories to retrieve per query (3–7 recommended)
top_k = 5
# Boost memories within N days in results (0 = disabled)
recency_boost_days = 7
# Where to generate embeddings: local (on device) | openai (OpenAI API) | external (use app-server)
embedding_source = local
# URL of the external app-server for embeddings (only used when embedding_source = external)
embedding_url =

[ACCESS]
# Enable web interface
webui_enabled = True
# Web interface port (80 = no port needed in browser URL)
webui_port = 80
# Web interface login password
webui_password = tarspassword
# Web UI color theme (auto-discovered from css/themes/ folder)
webui_theme = default

[UI]
# On-device display width in pixels (3.5" = 480, 5–7" = 800)
screen_width = 480
# On-device display height in pixels (3.5" = 320, 5" = 480)
screen_height = 320
# Enable on-device display (False = headless / no screen)
UI_enabled = True
# Enable Pi CSI camera module
use_camera_module = True
# Show mouse cursor on display (useful during dev/debug)
show_mouse = False
# Run display in fullscreen mode
fullscreen = True
# Show clock on screensaver
show_time = True
# Show CPU temperature on display
show_cpu_temp = False
# True = 12hr AM/PM, False = 24hr
ampm_format = True
# Default display app: terminal | dashboard | clock | eyes
app = terminal
# Display frame rate (30 = balanced; lower saves CPU)
target_fps = 30
# Display font size (3.5": 9–12, 5–7": 12–16, 10"+: 16–20)
font_size = 12
# Seconds of inactivity before screensaver (0 = disabled)
screensaver_timer = 300
# Seconds per screensaver when using multiple animations
screensaver_cycle_interval = 300
# Screensaver animations: random, or names like face,matrix,starfield (Available animations: blackhole, waves, matrix, starfield, hyperspace, terminal, face, fractal, pacman, nebulas, pictures, dashboard, defrag, bounce, endurance, toasters, aquarium, dream)
screensaver_list = random

[CONTROLS]
# Enable game controller support
enabled = False
# Periodically shift to ventilation pose to improve airflow
ventilate = False
# Allow voice commands to trigger physical movement
voicemovement = False
# Swap left/right turn directions if reversed
swap_turn_directions = False
# Invert Y-axis if up/down is reversed
invert_y = False
# Controller partial name to match (e.g., 8BitDo, Xbox, PS4)
controller_name = 8BitDo

[BATTERY]
# Enable battery monitoring (requires INA260 sensor)
battery_enabled = False
# Auto-shutdown at low battery to protect SD card and battery
battery_auto_shutdown = False
# Battery capacity in mAh (check battery label)
battery_capacity_mAh = 3000
# Full charge voltage (3S LiPo: 12.6V, 4S: 16.8V, USB: 5V)
battery_initial_voltage = 12
# Minimum safe discharge voltage (3S LiPo: 10.5V, 4S: 14V)
battery_cutoff_voltage = 10

[SERVO]
# True if arm servos are physically installed (affects movement calculations)
arms_present = False
# Servo 0 - Left leg height
leftUpHeight = 220
leftDownHeight = 460
perfectLeftHeightOffset = 0
# Servo 1 - Right leg height
rightUpHeight = 460
rightDownHeight = 220
perfectRightHeightOffset = 0
# Servo 2 - Left leg swing
forwardLeftLeg = 160
backLeftLeg = 460
perfectLeftLegOffset = 0
# Servo 3 - Right leg swing
forwardRightLeg = 460
backRightLeg = 160
perfectRightLegOffset = 0
# Left Arm
leftMainMin = 550
leftMainMax = 50
leftMainOffset = 0
leftForarmMin = 500
leftForarmMax = 230
leftForearmOffset = 0
leftHandMin = 420
leftHandMax = 300
leftHandOffset = 0
# Right Arm
rightMainMin = 50
rightMainMax = 550
rightMainOffset = 0
rightForarmMin = 230
rightForarmMax = 500
rightForearmOffset = 0
rightHandMin = 300
rightHandMax = 420
rightHandOffset = 0

[SKILL:discord]
disabled = true

[SKILL:home_assistant]
disabled = true

[SKILL:generate_image]
disabled = true

[SKILL:generate_music]
disabled = true

[SKILL:network_camera]
disabled = true

[SKILL:launch_retropie]
disabled = true